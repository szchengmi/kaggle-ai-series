# API Keys（Kaggle Secrets 或手动设置）
# 不要在此处填写真实密钥，通过环境变量或Kaggle Secrets注入
GOOGLE_API_KEY=
HF_TOKEN=

# 项目参数
EPISODE_NUM=1
GENRE=urban_romance
EPISODE_LENGTH=3-5分钟
NUM_SCENES=6
SHOTS_PER_SCENE=3

# 生成参数
IMAGE_STEPS=20
IMAGE_GUIDANCE=7.5
VIDEO_FPS=8
VIDEO_RESOLUTION=512

# 质量模式: fast / balanced / quality
QUALITY_MODE=fast
